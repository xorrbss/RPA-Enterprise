    "@vitejs/plugin-react": "^4.3.3",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "vitest-axe": "^0.1.0"
