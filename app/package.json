{
  "name": "rpa-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "D2+ 프로덕션 런타임 — 계약(ts/·schema/·db/)과 검증된 codegen 산출물을 PostgreSQL·Worker에 연결한다. 계약 SSoT는 상위 디렉터리(consumed, not redefined).",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:unit": "tsx test/flow-control.unit.ts",
    "test:int": "tsx test/run-transition.int.ts && tsx test/graphile-worker.int.ts"
  },
  "dependencies": {
    "graphile-worker": "^0.16.6",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10"
  }
}
