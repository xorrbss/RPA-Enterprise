{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpa.local/contracts/ir.schema.json",
  "title": "RPA Scenario IR v1",
  "description": "선언형 시나리오 IR. graph 노드 구조. 제어흐름은 한 Workitem 내부만. product 반복은 Workitem 전개가 담당.",
  "type": "object",
  "required": ["meta", "start", "nodes"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "ir_version": { "type": "string", "const": "1.x" },
        "studio_mode": {
          "type": "string",
          "enum": ["easy", "form", "ir"],
          "description": "콘솔 시나리오 스튜디오 편집 모드 보존. 편집 진입 시 같은 저코드/IR 모드로 복원한다."
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "screenshot": { "type": "string", "enum": ["never", "failure", "each_step"] },
            "video": { "type": "string", "enum": ["never", "failure", "always"] }
          },
          "description": "Natural-language scenario generation evidence request. screenshot maps to node.policy.recording; video is run-level and requires a runtime video recorder port before auto-run."
        }
      }
    },
    "params_schema": {
      "description": "실행 파라미터 JSON Schema. IREL params.* 타입 추론 근거.",
      "type": "object"
    },
    "assets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Assets 스토어 참조 키(값 아님)"
    },
    "start": { "type": "string", "description": "시작 노드 id" },
    "nodes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/node" },
      "minProperties": 1
    },
    "target": {
      "description": "실행 대상 선언(시나리오가 묶이는 사이트/아이덴티티/네트워크). 런타임 worker 의 BrowserLeasePlanResolver 가 run→scenario_version→ir.target 으로 해소한다. 미선언 시 drive 는 fail-closed(loud throw).",
      "type": "object",
      "required": ["site_profile_id", "browser_identity_id", "network_policy_id"],
      "additionalProperties": false,
      "properties": {
        "site_profile_id": { "type": "string", "format": "uuid", "description": "site_profiles(id) 참조(tenant-scoped)" },
        "browser_identity_id": { "type": "string", "format": "uuid", "description": "browser_identities(id) 참조(tenant-scoped)" },
        "network_policy_id": { "type": "string", "format": "uuid", "description": "network_policies(id) 참조(tenant-scoped). RunContext.networkPolicyId 대상" }
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "where": { "$ref": "#/$defs/where" },
        "what": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "verify": { "$ref": "#/$defs/verify" },
        "policy": { "$ref": "#/$defs/nodePolicy" },
        "side_effect": { "$ref": "#/$defs/sideEffect" },
        "next": { "$ref": "#/$defs/target" },
        "on": {
          "type": "array",
          "description": "[FIX] 분기 목록. 키 순서 의존 제거. priority 내림차순으로 when(IREL 불린식) 평가, 첫 true 채택. 동률 priority는 컴파일 거부(비결정 방지).",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["when", "target", "priority"],
            "additionalProperties": false,
            "properties": {
              "when": { "type": "string", "description": "IREL 불린식. 예: flags.blocked" },
              "target": { "$ref": "#/$defs/target" },
              "priority": { "type": "integer", "description": "높을수록 우선. 동률 금지(컴파일 검증)." }
            }
          }
        },
        "loop": {
          "type": "object",
          "required": ["body_target", "exit_target", "until", "max_iterations"],
          "additionalProperties": false,
          "properties": {
            "body_target": { "$ref": "#/$defs/nodeTarget", "description": "loop 본문 진입 노드 id" },
            "exit_target": { "$ref": "#/$defs/nodeTarget", "description": "until=true 또는 max_iterations 도달 시 탈출 노드 id" },
            "until": { "type": "string", "description": "IREL 불린식. 컴파일 타임 타입체크." },
            "max_iterations": { "type": "integer", "minimum": 1, "maximum": 10000, "description": "무한루프 가드 필수" }
          }
        },
        "fallback_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fallbackTier" },
          "description": "T0→T1→T2→T3 등. 순서대로 시도, advance_when 충족 시 다음 티어."
        },
        "terminal": {
          "type": "string",
          "enum": ["success", "success_empty", "fail_business", "fail_system"],
          "description": "종료 노드. 다른 흐름 키와 함께 쓸 수 없음."
        }
      },
      "$comment": "[FIX #11] 흐름 제어 키(next/on/loop/fallback_chain/terminal) 중 정확히 하나만 존재. 아래 oneOf가 강제(0개·2개 이상 모두 거부). 코드 검증 의존 제거.",
      "oneOf": [
        { "required": ["next"],           "not": { "anyOf": [ { "required": ["on"] }, { "required": ["loop"] }, { "required": ["fallback_chain"] }, { "required": ["terminal"] } ] } },
        { "required": ["on"],             "not": { "anyOf": [ { "required": ["next"] }, { "required": ["loop"] }, { "required": ["fallback_chain"] }, { "required": ["terminal"] } ] } },
        { "required": ["loop"],           "not": { "anyOf": [ { "required": ["next"] }, { "required": ["on"] }, { "required": ["fallback_chain"] }, { "required": ["terminal"] } ] } },
        { "required": ["fallback_chain"], "not": { "anyOf": [ { "required": ["next"] }, { "required": ["on"] }, { "required": ["loop"] }, { "required": ["terminal"] } ] } },
        { "required": ["terminal"],       "not": { "anyOf": [ { "required": ["next"] }, { "required": ["on"] }, { "required": ["loop"] }, { "required": ["fallback_chain"] } ] } }
      ]
    },
    "where": {
      "type": "object",
      "description": "상태 패턴. 생략 시 직전 PageState 계승.",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" },
        "page_intent": { "type": "string" },
        "selectors": { "type": "array", "items": { "type": "string" } },
        "logic": { "type": "string", "enum": ["AND", "OR", "NOT"], "default": "AND" },
        "priority": { "type": "integer", "description": "다중 매칭 시 우선순위(높을수록 우선)" }
      }
    },
    "action": {
      "type": "object",
      "required": ["action"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": ["act", "observe", "extract", "navigate", "download", "upload", "api_call", "file", "human_task", "shell"]
        },
        "instruction": { "type": "string", "minLength": 1 },
        "schema_ref": { "type": "string", "minLength": 1, "description": "extract 출력 스키마" },
        "vars": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Assets/credential 참조" },
        "url_ref": { "type": "string", "minLength": 1 },
        "cmd_ref": { "type": "string", "minLength": 1, "description": "shell 전용 — signed command registry 키. 미등록 시 거부." },
        "sensitive": { "type": "boolean", "default": false },
        "args": { "type": "object", "additionalProperties": true, "description": "action별 확장 입력은 최상위 오타 방지를 위해 args 아래에만 둔다." }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "shell" } } },
          "then": { "required": ["cmd_ref"] }
        },
        {
          "if": { "properties": { "action": { "const": "extract" } } },
          "then": { "required": ["instruction", "schema_ref"] }
        },
        {
          "if": { "properties": { "action": { "const": "navigate" } } },
          "then": { "required": ["url_ref"] }
        },
        {
          "if": { "properties": { "action": { "const": "api_call" } } },
          "then": {
            "required": ["url_ref", "args"],
            "properties": {
              "args": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "method": {
                    "type": "string",
                    "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "get", "post", "put", "patch", "delete"]
                  },
                  "headers": {
                    "type": "object",
                    "propertyNames": {
                      "not": {
                        "pattern": "^([Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Pp][Rr][Oo][Xx][Yy]-[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Ss][Ee][Tt]-[Cc][Oo][Oo][Kk][Ii][Ee]|[Xx]-[Aa][Pp][Ii]-[Kk][Ee][Yy])$"
                      }
                    },
                    "additionalProperties": { "type": "string" }
                  },
                  "auth": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": ["type"],
                        "additionalProperties": false,
                        "properties": { "type": { "const": "none" } }
                      },
                      {
                        "type": "object",
                        "required": ["type", "secret_ref"],
                        "additionalProperties": false,
                        "properties": {
                          "type": { "const": "secret_ref_bearer" },
                          "secret_ref": { "type": "string", "pattern": "^secret://.+" },
                          "connector_id": { "type": "string", "minLength": 1 }
                        }
                      }
                    ]
                  },
                  "idempotency_key": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "required": ["method"],
                      "properties": {
                        "method": { "enum": ["POST", "PUT", "PATCH", "DELETE", "post", "put", "patch", "delete"] }
                      }
                    },
                    "then": { "required": ["idempotency_key"] }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "verify": {
      "$ref": "verify.schema.json"
    },
    "nodePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 300000 },
        "max_self_heal": { "type": "integer", "minimum": 0, "default": 2 },
        "requires_approval": { "type": "boolean", "default": false },
        "recording": { "type": "string", "enum": ["always", "masked_on_failure", "never"], "default": "masked_on_failure" }
      }
    },
    "sideEffect": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["read_only", "login", "submit", "create", "update", "delete", "upload"] },
        "idempotent": { "type": "boolean" },
        "idempotency_key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$",
          "description": "비-read_only면 필수(코드 검증). 빈 키 금지."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "not": { "const": "read_only" } } } },
          "then": { "required": ["idempotency_key"] }
        }
      ]
    },
    "fallbackTier": {
      "type": "object",
      "required": ["tier", "entry_node"],
      "additionalProperties": false,
      "properties": {
        "tier": { "type": "string", "enum": ["T0", "T1", "T2", "T3"] },
        "entry_node": { "$ref": "#/$defs/nodeTarget", "description": "이 티어의 진입 노드 id" },
        "advance_when": { "type": "string", "description": "IREL 불린식. true면 다음 티어로 전환." }
      }
    },
    "target": {
      "oneOf": [
        { "$ref": "#/$defs/nodeTarget" },
        { "$ref": "#/$defs/endNoDataTarget" },
        { "$ref": "#/$defs/reservedHandlerCall" }
      ],
      "description": "노드 id, @end_no_data 터미널, 또는 복귀형 예약 핸들러 호출 객체."
    },
    "nodeTarget": {
      "type": "string",
      "description": "nodes에 정의되어야 하는 노드 id.",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    },
    "endNoDataTarget": {
      "type": "string",
      "description": "@end_no_data는 return_node 없는 터미널 target이다.",
      "const": "@end_no_data"
    },
    "reservedHandlerCall": {
      "$comment": "복귀형 예약 핸들러 호출 객체. @end_no_data는 터미널이므로 이 객체에 포함하지 않는다.",
      "type": "object",
      "required": ["handler", "input", "return_node"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "handler": { "const": "@challenge" } }, "required": ["handler"] },
          "then": { "properties": { "input": { "type": "object", "additionalProperties": false } } }
        },
        {
          "if": { "properties": { "handler": { "const": "@human_task" } }, "required": ["handler"] },
          "then": { "properties": { "input": { "$ref": "#/$defs/humanTaskInput" } } }
        }
      ],
      "properties": {
        "handler": { "type": "string", "enum": ["@challenge", "@human_task"] },
        "input": {
          "type": "object",
          "description": "핸들러별 명시 입력. 상세 의미는 reserved-handlers.md가 권위이며, 호출 객체 자체는 closed shape이다."
        },
        "return_node": { "$ref": "#/$defs/nodeTarget", "description": "핸들러 resolved 후 재개할 노드 id" }
      }
    },
    "humanTaskInput": {
      "type": "object",
      "required": ["assignee_role"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["approval", "validation", "exception"] },
        "payload": { "type": "object" },
        "result_schema": { "$ref": "#/$defs/humanTaskResultSchema" },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assignee_role": { "type": "string", "minLength": 1 },
        "timeout": { "type": "string" },
        "on_timeout": { "type": "string", "enum": ["fail", "escalate"] }
      }
    },
    "humanTaskResultSchema": {
      "oneOf": [
        { "$ref": "#/$defs/businessFormSchema" },
        {
          "type": "object",
          "not": { "required": ["version"] },
          "additionalProperties": true
        }
      ]
    },
    "businessFormSchema": {
      "type": "object",
      "required": ["version", "fields"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "const": "business_form_v1" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/businessFormField" }
        }
      }
    },
    "businessFormField": {
      "type": "object",
      "required": ["key", "label", "type"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,63}$" },
        "label": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["text", "textarea", "number", "boolean", "date", "select"] },
        "required": { "type": "boolean" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "help_text": { "type": "string" }
      }
    }
  }
}
